root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.rs]
indent_size = 4

[*.{toml,yml,yaml,json,html,css,js}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false  # trailing spaces are a hard line break
